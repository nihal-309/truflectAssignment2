/**
 * Complete Retry Logic - Reusable Pattern for Next.js Projects
 * 
 * Usage:
 * 1. Copy this entire file to your new project
 * 2. Use the hooks and utilities as shown in examples below
 * 3. Customize the retry attempts and fallback logic as needed
 */

import { useState, useCallback } from 'react';

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

export interface RetryState {
  loading: boolean;
  error: string;
  retryCount: number;
  hasData: boolean;
}

export interface RetryConfig {
  maxAttempts?: number;
  delayMs?: number;
  exponentialBackoff?: boolean;
}

// ============================================================================
// UTILITY: Fetch with Retry
// ============================================================================

export async function fetchWithRetry<T>(
  fetchFn: () => Promise<T>,
  config: RetryConfig = {}
): Promise<T> {
  const {
    maxAttempts = 3,
    delayMs = 100,
    exponentialBackoff = true,
  } = config;

  let lastError: Error | null = null;

  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    try {
      return await fetchFn();
    } catch (err) {
      lastError = err as Error;
      console.error(`Attempt ${attempt}/${maxAttempts} failed:`, err);

      if (attempt < maxAttempts) {
        const delay = exponentialBackoff ? delayMs * Math.pow(2, attempt - 1) : delayMs;
        await new Promise(resolve => setTimeout(resolve, delay));
      }
    }
  }

  throw lastError || new Error('Max retry attempts exceeded');
}

// ============================================================================
// HOOK: useRetry - Complete Retry State Management
// ============================================================================

export interface UseRetryReturn<T> {
  data: T[];
  loading: boolean;
  error: string;
  retryCount: number;
  showRetry: boolean;
  handleRetry: () => Promise<void>;
  setState: {
    setData: (data: T[]) => void;
    setError: (error: string) => void;
    setLoading: (loading: boolean) => void;
    clearError: () => void;
    resetState: () => void;
  };
}

export function useRetry<T>(
  fetchFn: () => Promise<T[]>,
  config: RetryConfig = {}
): UseRetryReturn<T> {
  const [data, setData] = useState<T[]>([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  const [retryCount, setRetryCount] = useState(0);

  // Determine if retry button should show (error + no data loaded yet)
  const showRetry = Boolean(error) && data.length === 0;

  // Main fetch function with retry logic
  const executeRetry = useCallback(async () => {
    try {
      setLoading(true);
      setError('');

      const result = await fetchWithRetry(fetchFn, config);
      setData(result);
      setRetryCount(0);
    } catch (err) {
      const errorMsg = err instanceof Error ? err.message : 'Failed to load data';
      setError(errorMsg);
      setRetryCount(prev => prev + 1);
      console.error('Retry exhausted:', err);
    } finally {
      setLoading(false);
    }
  }, [fetchFn, config]);

  // Retry handler with state reset
  const handleRetry = useCallback(async () => {
    setData([]);
    setError('');
    setLoading(true);
    
    // Small delay to ensure state updates
    await new Promise(resolve => setTimeout(resolve, 100));
    
    await executeRetry();
  }, [executeRetry]);

  return {
    data,
    loading,
    error,
    retryCount,
    showRetry,
    handleRetry,
    setState: {
      setData,
      setError,
      setLoading,
      clearError: () => setError(''),
      resetState: () => {
        setData([]);
        setError('');
        setLoading(false);
        setRetryCount(0);
      },
    },
  };
}

// ============================================================================
// HOOK: useRetryWithFallback - With Primary and Fallback Fetch Logic
// ============================================================================

export interface RetryWithFallbackConfig extends RetryConfig {
  fallbackDelay?: number;
}

export async function fetchWithFallback<T>(
  primaryFn: () => Promise<T>,
  fallbackFn: () => Promise<T>,
  config: RetryWithFallbackConfig = {}
): Promise<T> {
  const {
    maxAttempts = 2,
    delayMs = 100,
    fallbackDelay = 500,
  } = config;

  // Try primary approach
  let primaryError: Error | null = null;
  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    try {
      return await primaryFn();
    } catch (err) {
      primaryError = err as Error;
      console.error(`Primary attempt ${attempt}/${maxAttempts} failed:`, err);
      if (attempt < maxAttempts) {
        await new Promise(resolve => setTimeout(resolve, delayMs));
      }
    }
  }

  console.log('Primary approach failed, attempting fallback...');

  // Wait before trying fallback
  await new Promise(resolve => setTimeout(resolve, fallbackDelay));

  // Try fallback approach
  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    try {
      return await fallbackFn();
    } catch (err) {
      console.error(`Fallback attempt ${attempt}/${maxAttempts} failed:`, err);
      if (attempt < maxAttempts) {
        await new Promise(resolve => setTimeout(resolve, delayMs));
      }
    }
  }

  throw primaryError || new Error('Both primary and fallback approaches failed');
}

export function useRetryWithFallback<T>(
  primaryFn: () => Promise<T[]>,
  fallbackFn: () => Promise<T[]>,
  config: RetryWithFallbackConfig = {}
): UseRetryReturn<T> {
  const [data, setData] = useState<T[]>([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  const [retryCount, setRetryCount] = useState(0);

  const showRetry = Boolean(error) && data.length === 0;

  const executeRetry = useCallback(async () => {
    try {
      setLoading(true);
      setError('');

      const result = await fetchWithFallback(primaryFn, fallbackFn, config);
      setData(result);
      setRetryCount(0);
    } catch (err) {
      const errorMsg = err instanceof Error ? err.message : 'Failed to load data';
      setError(errorMsg);
      setRetryCount(prev => prev + 1);
      console.error('Retry exhausted:', err);
    } finally {
      setLoading(false);
    }
  }, [primaryFn, fallbackFn, config]);

  const handleRetry = useCallback(async () => {
    setData([]);
    setError('');
    await new Promise(resolve => setTimeout(resolve, 100));
    await executeRetry();
  }, [executeRetry]);

  return {
    data,
    loading,
    error,
    retryCount,
    showRetry,
    handleRetry,
    setState: {
      setData,
      setError,
      setLoading,
      clearError: () => setError(''),
      resetState: () => {
        setData([]);
        setError('');
        setLoading(false);
        setRetryCount(0);
      },
    },
  };
}

