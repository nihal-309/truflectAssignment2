// ============================================================================
// CONDITIONAL RETRY BUTTON DISPLAY LOGIC
// ============================================================================

/**
 * Determines if retry button should be shown based on:
 * 1. Error exists
 * 2. No data has been loaded yet
 * 
 * This ensures retry button appears only when API completely failed,
 * not when user has partial data (like failed infinite scroll)
 */
export function shouldShowRetryButton(
  error: string,
  dataLength: number
): boolean {
  return Boolean(error) && dataLength === 0;
}

/**
 * Alternative: Show retry button if error exists AND:
 * - No data loaded, OR
 * - Retries exceeded maximum attempts
 */
export function shouldShowRetryButtonAdvanced(
  error: string,
  dataLength: number,
  retryCount: number,
  maxRetries: number = 3
): boolean {
  return Boolean(error) && (dataLength === 0 || retryCount >= maxRetries);
}

// ============================================================================
// UI COMPONENT PATTERNS
// ============================================================================

/**
 * Reusable Error Retry Component
 */
export interface ErrorRetryDisplayProps {
  error: string;
  isVisible: boolean;
  onRetry: () => void;
  isLoading?: boolean;
  retryCount?: number;
  maxRetries?: number;
}

export const ErrorRetryDisplay: React.FC<ErrorRetryDisplayProps> = ({
  error,
  isVisible,
  onRetry: handleRetry,
  isLoading = false,
  retryCount = 0,
  maxRetries = 3,
}) => {
  if (!isVisible) return null;

  const isMaxRetriesExceeded = retryCount >= maxRetries;

  return (
    <div className="bg-red-50 border border-red-300 rounded-lg p-4 mb-4">
      <div className="flex items-center justify-between gap-4">
        <div>
          <p className="text-red-700 font-semibold">Error Loading Data</p>
          <p className="text-red-600 text-sm">{error}</p>
          {retryCount > 0 && (
            <p className="text-red-500 text-xs mt-1">
              Attempts: {retryCount}/{maxRetries}
            </p>
          )}
        </div>
        <button
          onClick={handleRetry}
          disabled={isLoading || isMaxRetriesExceeded}
          className="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {isLoading ? 'Retrying...' : 'Try Again'}
        </button>
      </div>
      {isMaxRetriesExceeded && (
        <p className="text-red-500 text-xs mt-2">Maximum retry attempts exceeded</p>
      )}
    </div>
  );
};

export default {
  fetchWithRetry,
  fetchWithFallback,
  useRetry,
  useRetryWithFallback,
  shouldShowRetryButton,
  shouldShowRetryButtonAdvanced,
  ErrorRetryDisplay,
};
